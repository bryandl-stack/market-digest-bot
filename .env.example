# ── Telegram 유저 세션 (my.telegram.org 에서 발급) ──
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── Telegram Bot (다이제스트 전송용) ──
# @BotFather 로 봇 생성 → 토큰. 봇에 /start 후 `python3 digest.py chatid` 로 chat_id 확인.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── FRED (선택 — 캘린더 경제지표 forward 보강) ──
# 없으면 경제지표 일부만 스킵되고 나머지는 정상. fred.stlouisfed.org 에서 무료 발급.
FRED_API_KEY=
